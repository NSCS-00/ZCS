<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>零核服务器 - 系统设置</title>
    <%- include('./partials/head'); %>
</head>
<body>
    <%- include('./partials/sidebar', { user: user, currentPath: currentPath }); %>

    <div class="content">
        <div class="container">
            <div class="header">
                <h1 class="title">设置</h1>
            </div>

            <% if (user.error) { %>
                <div class="status error" style="display: block;"><%= user.error %></div>
            <% } %>

            <% if (user.success) { %>
                <div class="status success" style="display: block;"><%= user.success %></div>
            <% } %>

            <div class="card">
                <h2>个人信息</h2>
                <form action="/settings" method="post" enctype="multipart/form-data">
                    <div style="display: flex; gap: 30px; flex-wrap: wrap;">
                        <div style="flex: 1; min-width: 250px;">
                            <label for="newName" class="input-label">用户名</label>
                            <input type="text" id="newName" name="newName" value="<%= user.name %>" class="input-field">

                            <label for="avatar" class="input-label">头像上传</label>
                            <input type="file" id="avatar" name="avatar" accept="image/*" class="input-field">

                            <label for="background" class="input-label">背景图上传</label>
                            <input type="file" id="background" name="background" accept="image/*" class="input-field">

                            <label for="theme" class="input-label">主题</label>
                            <select id="theme" name="theme" class="input-field">
                                <option value="dark" <%= (user.theme === 'light' ? '' : 'selected') %>>深色模式</option>
                                <option value="light" <%= (user.theme === 'light' ? 'selected' : '') %>>浅色模式</option>
                            </select>
                        </div>

                        <div style="flex: 1; min-width: 250px;">
                            <label for="oldPassword" class="input-label">原密码</label>
                            <input type="password" id="oldPassword" name="oldPassword" placeholder="输入原密码以修改" class="input-field">

                            <label for="newPassword" class="input-label">新密码</label>
                            <input type="password" id="newPassword" name="newPassword" placeholder="留空则不修改密码" class="input-field">

                            <label for="confirmNewPassword" class="input-label">确认新密码</label>
                            <input type="password" id="confirmNewPassword" name="confirmNewPassword" placeholder="再次输入新密码" class="input-field">
                        </div>
                    </div>

                    <button type="submit" class="button button-primary">保存设置</button>
                </form>
            </div>

            <div class="card">
                <h2>个人简介</h2>
                <form action="/settings/intro" method="post">
                    <div style="margin-bottom: 15px;">
                        <label for="introContent" class="input-label">简介内容 (支持Markdown格式)</label>
                        <div style="display: flex; gap: 5px; margin-bottom: 10px;">
                            <button type="button" onclick="insertMarkdown('# ', 'introContent')" class="button button-secondary">标题</button>
                            <button type="button" onclick="insertMarkdown('**', 'introContent', '**')" class="button button-secondary">粗体</button>
                            <button type="button" onclick="insertMarkdown('*', 'introContent', '*')" class="button button-secondary">斜体</button>
                            <button type="button" onclick="insertMarkdown('[', 'introContent', '](url)')" class="button button-secondary">链接</button>
                            <button type="button" onclick="insertMarkdown('`', 'introContent', '`')" class="button button-secondary">代码</button>
                            <button type="button" onclick="insertMarkdown('```\n', 'introContent', '\n```')" class="button button-secondary">代码块</button>
                        </div>
                        <textarea id="introContent" name="introContent" rows="10" class="input-field" placeholder="在这里输入您的个人简介，支持Markdown格式..."><%= introContent || '' %></textarea>
                    </div>
                    <button type="submit" class="button button-primary">保存简介</button>
                </form>
            </div>

            <div class="card">
                <h2>账户信息</h2>
                <ul>
                    <li>UUID: <%= user.UUID %></li>
                    <li>权限: <%= user.author %></li>
                    <li>积分: <%= user.points || 0 %></li>
                    <li>注册时间: <%= user.time %></li>
                </ul>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts'); %>

    <script>
        // 显示成功或错误消息
        document.addEventListener('DOMContentLoaded', function() {
            const statusElements = document.querySelectorAll('.status');
            statusElements.forEach(el => {
                if (el.textContent.trim() !== '') {
                    el.style.display = 'block';
                    // 3秒后自动隐藏
                    setTimeout(() => {
                        el.style.display = 'none';
                    }, 3000);
                }
            });

            // 如果用户有保存的主题设置，应用它
            <% if (typeof user !== 'undefined' && user && user.theme) { %>
                document.documentElement.setAttribute('data-theme', '<%= user.theme %>');
                localStorage.setItem('theme', '<%= user.theme %>');
            <% } %>
        });

        // Markdown插入函数
        function insertMarkdown(prefix, textareaId, suffix) {
            const textarea = document.getElementById(textareaId);
            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const selectedText = textarea.value.substring(start, end);

            let newText;
            if (suffix) {
                newText = prefix + selectedText + suffix;
            } else {
                newText = prefix + selectedText;
            }

            // 替换选中的文本
            textarea.value = textarea.value.substring(0, start) + newText + textarea.value.substring(end);

            // 重新设置光标位置
            const newCursorPos = start + newText.length;
            textarea.setSelectionRange(newCursorPos, newCursorPos);

            // 聚焦到文本框
            textarea.focus();
        }

    </script>
</body>
</html>