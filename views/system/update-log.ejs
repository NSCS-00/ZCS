<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>零核服务器 - 更新日志</title>
    <%- include('./partials/head'); %>
    <style>
        .update-log-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .log-title {
            font-size: 1.8rem;
            margin-bottom: 20px;
            color: var(--accent-color);
            text-align: center;
        }

        .log-entry {
            background-color: var(--bg-tertiary);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: var(--shadow-light);
            border-left: 4px solid var(--accent-color);
        }

        .log-version {
            font-size: 1.4rem;
            font-weight: bold;
            color: var(--accent-color);
            margin-bottom: 10px;
        }

        .log-date {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 15px;
        }

        .log-content {
            line-height: 1.6;
        }

        .log-content ul {
            padding-left: 20px;
            margin: 10px 0;
        }

        .log-content li {
            margin: 8px 0;
        }

        .log-content p {
            margin: 10px 0;
        }

        .log-content h3 {
            color: var(--accent-hover);
            margin: 15px 0 10px 0;
        }

        .log-content code {
            background-color: var(--bg-secondary);
            padding: 2px 6px;
            border-radius: 3px;
            font-family: 'Courier New', monospace;
        }

        .log-content pre {
            background-color: var(--bg-secondary);
            padding: 12px;
            border-radius: 5px;
            overflow-x: auto;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <%- include('./partials/sidebar', { user: user, currentPath: currentPath }); %>

    <div class="content">
        <div class="update-log-container">
            <h1 class="log-title">更新日志</h1>

            <% if (updateLogs && updateLogs.length > 0) { %>
                <% updateLogs.forEach(function(log) { %>
                    <div class="log-entry">
                        <div class="log-version">版本 <%= log.version %></div>
                        <div class="log-date"><%= log.time %></div>
                        <div class="log-content">
                            <ul>
                                <% for (let i = 1; i <= log.quantity; i++) { %>
                                    <% if (log[i]) { %>
                                        <li><%= log[i] %></li>
                                    <% } %>
                                <% } %>
                            </ul>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="log-entry">
                    <div class="log-version">暂无更新日志</div>
                    <div class="log-content">
                        <p>系统暂未记录任何更新信息。</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('./partials/scripts'); %>
</body>
</html>