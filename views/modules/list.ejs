<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>零核服务器 - 模块列表</title>
    <%- include('../partials/head'); %>
    <style>
        .search-panel {
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .search-input {
            flex: 1;
            padding: 10px 15px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-size: 1rem;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .modules-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .module-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 20px;
            transition: transform var(--transition-fast), box-shadow var(--transition-fast);
            position: relative;
        }

        .module-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
        }

        .module-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .module-name {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--accent-color);
            margin: 0;
        }

        .module-version {
            background: var(--accent-color);
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.8rem;
        }

        .module-intro {
            color: var(--text-secondary);
            line-height: 1.5;
            margin: 10px 0;
            white-space: pre-line; /* 保持换行符 */
        }

        .module-actions {
            margin-top: 15px;
            text-align: right;
        }

        .api-module {
            opacity: 0.7;
            border-style: dashed;
        }

        .api-module .module-name {
            color: var(--text-tertiary);
        }

        .favorite-btn {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.5rem;
            color: var(--text-secondary);
            transition: color var(--transition-fast);
            padding: 5px;
        }

        .favorite-btn:hover {
            color: var(--accent-color);
        }

        .favorite-btn.active {
            color: #ff6b6b;
        }

        .favorite-count {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-left: 5px;
        }

        .comment-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
        }

        .comment-modal-content {
            background-color: var(--bg-secondary);
            margin: 5% auto;
            padding: 20px;
            border-radius: 8px;
            width: 80%;
            max-width: 800px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .comment-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

        .close-modal {
            color: var(--text-secondary);
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close-modal:hover {
            color: var(--text-primary);
        }

        .comment-input-area {
            margin-bottom: 20px;
        }

        .comment-textarea {
            width: 100%;
            min-height: 80px;
            padding: 10px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-size: 1rem;
            resize: vertical;
        }

        .comment-textarea:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .comment-list {
            margin-top: 20px;
        }

        .comment-item {
            background: var(--bg-tertiary);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .comment-header {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }

        .comment-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            margin-right: 10px;
        }

        .comment-author {
            font-weight: bold;
            color: var(--accent-color);
        }

        .comment-date {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-left: 10px;
        }

        .comment-content {
            color: var(--text-primary);
            line-height: 1.6;
        }

        .comment-replies {
            margin-top: 10px;
            padding-left: 20px;
            border-left: 2px solid var(--border-color);
        }

        .comment-actions {
            margin-top: 10px;
            display: flex;
            gap: 10px;
        }

        .comment-action-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.9rem;
            padding: 5px 10px;
        }

        .comment-action-btn:hover {
            color: var(--accent-color);
        }

        .reply-form {
            margin-top: 10px;
            padding: 10px;
            background: var(--bg-secondary);
            border-radius: 8px;
            display: none;
        }

        .reply-form.show {
            display: block;
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { user: user, currentPath: currentPath }); %>

    <div class="content">
        <div class="container">
            <div class="header">
                <h1 class="title">模块列表</h1>
            </div>

            <div class="card">
                <div class="search-panel">
                    <input type="text" id="searchInput" class="search-input" placeholder="搜索模块（按模块名或作者）...">
                    <button id="searchBtn" class="button button-primary">搜索</button>
                    <button id="clearSearchBtn" class="button button-secondary">清除</button>
                </div>

                <h2>功能模块</h2>
                <% if (pageModules.length > 0) { %>
                    <div class="modules-container" id="pageModulesContainer">
                        <% pageModules.forEach(module => { %>
                            <div class="module-card" data-module-id="<%= module.dirName %>" data-module-name="<%= module.name.toLowerCase() %>" data-module-author="<%= (module.author || '').toLowerCase() %>">
                                <div class="module-header">
                                    <h3 class="module-name"><%= module.name %></h3>
                                    <div style="display: flex; align-items: center;">
                                        <button class="favorite-btn" data-module-id="<%= module.dirName %>" title="收藏模块">
                                            ☆
                                        </button>
                                        <span class="favorite-count" id="fav-count-<%= module.dirName %>">0</span>
                                        <button class="favorite-btn comment-btn" data-module-id="<%= module.dirName %>" title="查看评论" style="font-size: 1.2rem; margin-left: 8px;">
                                            💬
                                        </button>
                                        <span class="favorite-count" id="comment-count-<%= module.dirName %>">0</span>
                                        <span class="module-version">v<%= module.version %></span>
                                    </div>
                                </div>
                                <div class="module-intro"><%- typeof marked !== 'undefined' ? marked.parse(module.intro || '') : (module.intro || '').replace(/\n/g, '<br>') %></div>
                                <div class="module-actions">
                                    <a href="/module/<%= module.dirName %>" target="_blank" class="button button-primary">进入模块</a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p>暂无可用的功能模块</p>
                <% } %>
            </div>

            <% if (apiModules.length > 0) { %>
                <div class="card">
                    <h2>API模块</h2>
                    <div class="modules-container">
                        <% apiModules.forEach(module => { %>
                            <div class="module-card api-module">
                                <div class="module-header">
                                    <h3 class="module-name"><%= module.name %></h3>
                                    <span class="module-version">v<%= module.version %></span>
                                </div>
                                <div class="module-intro"><%- typeof marked !== 'undefined' ? marked.parse(module.intro || '') : (module.intro || '').replace(/\n/g, '<br>') %></div>
                                <div class="module-actions">
                                    <span class="text-muted">API模块，无用户界面</span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- 评论弹窗 -->
    <div id="commentModal" class="comment-modal">
        <div class="comment-modal-content">
            <div class="comment-modal-header">
                <h2 id="commentModalTitle">模块评论</h2>
                <span class="close-modal">&times;</span>
            </div>
            <div class="comment-input-area">
                <textarea id="commentTextarea" class="comment-textarea" placeholder="写下你的评论..."></textarea>
                <button id="submitCommentBtn" class="button button-primary" style="margin-top: 10px;">发表评论</button>
            </div>
            <div id="commentList" class="comment-list">
                <!-- 评论列表将在这里动态加载 -->
            </div>
        </div>
    </div>

    <%- include('../partials/scripts'); %>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        // 当前打开评论的模块 ID
        let currentModuleId = null;
        // 用户收藏的模块列表
        let userFavorites = [];

        // 加载用户收藏列表
        async function loadUserFavorites() {
            try {
                const response = await fetch('/api/module/favorites');
                const data = await response.json();
                if (data.success) {
                    userFavorites = data.favorites;
                    updateFavoriteButtons();
                }
            } catch (error) {
                console.error('加载收藏列表失败:', error);
            }
        }

        // 更新收藏按钮状态
        function updateFavoriteButtons() {
            document.querySelectorAll('.favorite-btn').forEach(btn => {
                const moduleId = btn.dataset.moduleId;
                if (userFavorites.includes(moduleId)) {
                    btn.classList.add('active');
                    btn.textContent = '★';
                } else {
                    btn.classList.remove('active');
                    btn.textContent = '☆';
                }
            });
        }

        // 加载模块收藏数量
        async function loadFavoriteCounts() {
            const moduleCards = document.querySelectorAll('.module-card');
            for (const card of moduleCards) {
                const moduleId = card.dataset.moduleId;
                try {
                    const response = await fetch(`/api/module/favorite-count/${moduleId}`);
                    const data = await response.json();
                    if (data.success) {
                        const countEl = document.getElementById(`fav-count-${moduleId}`);
                        if (countEl) {
                            countEl.textContent = data.count;
                        }
                    }
                } catch (error) {
                    console.error(`加载模块 ${moduleId} 收藏数量失败:`, error);
                }
            }
        }

        // 收藏/取消收藏模块
        async function toggleFavorite(moduleId) {
            const isFavorited = userFavorites.includes(moduleId);
            const action = isFavorited ? 'remove' : 'add';

            try {
                const response = await fetch('/api/module/favorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ moduleId, action })
                });

                const result = await response.json();
                if (result.success) {
                    if (action === 'add') {
                        userFavorites.push(moduleId);
                    } else {
                        userFavorites = userFavorites.filter(id => id !== moduleId);
                    }
                    updateFavoriteButtons();
                    loadFavoriteCounts();
                    alert(result.message);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                console.error('收藏操作失败:', error);
                alert('收藏操作失败，请重试');
            }
        }

        // 搜索模块
        function searchModules() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const moduleCards = document.querySelectorAll('.module-card');

            moduleCards.forEach(card => {
                const moduleName = card.dataset.moduleName;
                const moduleAuthor = card.dataset.moduleAuthor;

                if (moduleName.includes(searchTerm) || moduleAuthor.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // 清除搜索
        function clearSearch() {
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.module-card').forEach(card => {
                card.style.display = 'block';
            });
        }

        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', function() {
            loadUserFavorites();
            loadFavoriteCounts();

            // 绑定收藏按钮事件
            document.querySelectorAll('.favorite-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const moduleId = this.dataset.moduleId;
                    toggleFavorite(moduleId);
                });
            });

            // 绑定搜索事件
            document.getElementById('searchBtn').addEventListener('click', searchModules);
            document.getElementById('clearSearchBtn').addEventListener('click', clearSearch);
            document.getElementById('searchInput').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    searchModules();
                }
            });

            // 评论功能
            const commentModal = document.getElementById('commentModal');
            const closeModal = document.querySelector('.close-modal');
            const submitCommentBtn = document.getElementById('submitCommentBtn');
            const commentTextarea = document.getElementById('commentTextarea');
            const commentList = document.getElementById('commentList');
            const commentModalTitle = document.getElementById('commentModalTitle');

            // 打开评论弹窗
            document.querySelectorAll('.comment-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    currentModuleId = this.dataset.moduleId;
                    const moduleName = this.closest('.module-card').querySelector('.module-name').textContent;
                    commentModalTitle.textContent = `${moduleName} - 评论`;
                    commentModal.style.display = 'block';
                    loadComments(currentModuleId);
                    loadCommentCount(currentModuleId);
                });
            });

            // 关闭评论弹窗
            closeModal.addEventListener('click', function() {
                commentModal.style.display = 'none';
                currentModuleId = null;
            });

            // 点击弹窗外部关闭
            window.addEventListener('click', function(e) {
                if (e.target === commentModal) {
                    commentModal.style.display = 'none';
                    currentModuleId = null;
                }
            });

            // 提交评论
            submitCommentBtn.addEventListener('click', submitComment);
            commentTextarea.addEventListener('keypress', function(e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    submitComment();
                }
            });

            // 加载评论
            async function loadComments(moduleId) {
                try {
                    const response = await fetch(`/api/module/comments/${moduleId}`);
                    const data = await response.json();
                    if (data.success) {
                        renderComments(data.comments);
                    }
                } catch (error) {
                    console.error('加载评论失败:', error);
                }
            }

            // 渲染评论
            function renderComments(comments) {
                commentList.innerHTML = '';
                if (comments.length === 0) {
                    commentList.innerHTML = '<p style="text-align: center; color: var(--text-secondary);">暂无评论</p>';
                    return;
                }

                comments.forEach(comment => {
                    const commentEl = createCommentElement(comment);
                    commentList.appendChild(commentEl);
                });
            }

            // 创建评论元素
            function createCommentElement(comment, isReply = false) {
                const div = document.createElement('div');
                div.className = isReply ? 'comment-item' : 'comment-item';
                div.style.marginLeft = isReply ? '20px' : '0';
                div.style.borderLeft = isReply ? '2px solid var(--border-color)' : 'none';
                div.style.paddingLeft = isReply ? '15px' : '15px';
                div.dataset.commentId = comment.id;

                const date = new Date(comment.createdAt).toLocaleString('zh-CN');

                div.innerHTML = `
                    <div class="comment-header">
                        <img src="${comment.userAvatar}" alt="${comment.userName}" class="comment-avatar" onerror="this.src='/images/default-avatar.png'">
                        <span class="comment-author">${comment.userName}</span>
                        <span class="comment-date">${date}</span>
                    </div>
                    <div class="comment-content">${comment.content}</div>
                    <div class="comment-actions">
                        <button class="comment-action-btn reply-btn" data-comment-id="${comment.id}">回复</button>
                        ${comment.userId === '<%= user.UUID %>' || '<%= user.author %>' === 'system' ? 
                          '<button class="comment-action-btn delete-btn" data-comment-id="' + comment.id + '">删除</button>' : ''}
                    </div>
                    <div class="reply-form" id="reply-form-${comment.id}">
                        <textarea class="comment-textarea" placeholder="写下你的回复..." style="min-height: 60px;"></textarea>
                        <button class="button button-primary submit-reply-btn" style="margin-top: 10px;" data-parent-id="${comment.id}">提交回复</button>
                        <button class="button button-secondary cancel-reply-btn" style="margin-top: 10px; margin-left: 10px;">取消</button>
                    </div>
                `;

                // 绑定回复按钮事件
                div.querySelector('.reply-btn').addEventListener('click', function() {
                    const replyForm = div.querySelector(`#reply-form-${comment.id}`);
                    replyForm.classList.toggle('show');
                });

                // 绑定取消回复按钮事件
                div.querySelector('.cancel-reply-btn').addEventListener('click', function() {
                    const replyForm = div.querySelector(`#reply-form-${comment.id}`);
                    replyForm.classList.remove('show');
                });

                // 绑定提交回复按钮事件
                div.querySelector('.submit-reply-btn').addEventListener('click', function() {
                    const replyForm = div.querySelector(`#reply-form-${comment.id}`);
                    const textarea = replyForm.querySelector('textarea');
                    const content = textarea.value.trim();
                    if (content) {
                        submitReply(comment.id, content);
                        textarea.value = '';
                        replyForm.classList.remove('show');
                    }
                });

                // 绑定删除按钮事件
                const deleteBtn = div.querySelector('.delete-btn');
                if (deleteBtn) {
                    deleteBtn.addEventListener('click', function() {
                        deleteComment(comment.id);
                    });
                }

                // 渲染回复
                if (comment.replies && comment.replies.length > 0) {
                    const repliesDiv = document.createElement('div');
                    repliesDiv.className = 'comment-replies';
                    comment.replies.forEach(reply => {
                        const replyEl = createCommentElement(reply, true);
                        repliesDiv.appendChild(replyEl);
                    });
                    div.appendChild(repliesDiv);
                }

                return div;
            }

            // 提交评论
            async function submitComment() {
                const content = commentTextarea.value.trim();
                if (!content) {
                    alert('请输入评论内容');
                    return;
                }

                try {
                    const response = await fetch('/api/module/comments', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            moduleId: currentModuleId,
                            content: content
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('评论成功');
                        commentTextarea.value = '';
                        loadComments(currentModuleId);
                        loadCommentCount(currentModuleId);
                    } else {
                        alert(result.message);
                    }
                } catch (error) {
                    console.error('提交评论失败:', error);
                    alert('提交评论失败，请重试');
                }
            }

            // 提交回复
            async function submitReply(parentId, content) {
                try {
                    const response = await fetch('/api/module/comments', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            moduleId: currentModuleId,
                            content: content,
                            parentId: parentId
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('回复成功');
                        loadComments(currentModuleId);
                    } else {
                        alert(result.message);
                    }
                } catch (error) {
                    console.error('提交回复失败:', error);
                    alert('提交回复失败，请重试');
                }
            }

            // 删除评论
            async function deleteComment(commentId) {
                if (!confirm('确定要删除这条评论吗？')) {
                    return;
                }

                try {
                    const response = await fetch(`/api/module/comments/${currentModuleId}/${commentId}`, {
                        method: 'DELETE'
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('删除成功');
                        loadComments(currentModuleId);
                        loadCommentCount(currentModuleId);
                    } else {
                        alert(result.message);
                    }
                } catch (error) {
                    console.error('删除评论失败:', error);
                    alert('删除评论失败，请重试');
                }
            }

            // 加载评论数量
            async function loadCommentCount(moduleId) {
                // 这里可以通过 API 获取评论数量并显示
                // 暂时从评论列表获取
            }
        });
    </script>
</body>
</html>