<%- include('../system/layout', { title: '积分池管理' }) %>

<div class="container">
  <div class="header">
    <h1>💰 积分池管理</h1>
    <a href="/panel" class="button">返回管理面板</a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <!-- 积分池统计 -->
  <div class="stats-grid">
    <div class="stat-card">
      <h3>📦 可用积分</h3>
      <p class="stat-value" id="availableCredits">-</p>
    </div>
    <div class="stat-card">
      <h3>💼 已分配积分</h3>
      <p class="stat-value" id="allocatedCredits">-</p>
    </div>
    <div class="stat-card">
      <h3>📊 累计生成</h3>
      <p class="stat-value" id="totalGenerated">-</p>
    </div>
    <div class="stat-card">
      <h3>♻️ 累计回收</h3>
      <p class="stat-value" id="totalRecycled">-</p>
    </div>
  </div>

  <!-- 操作区域 -->
  <div class="action-grid">
    <!-- 生成积分 -->
    <div class="card">
      <h2>🔨 生成积分</h2>
      <form id="generateForm" onsubmit="return generateCredits(event)">
        <div class="form-group">
          <label>生成数量</label>
          <input type="number" id="generateAmount" min="1" max="1000" value="100" required />
        </div>
        <div class="form-group">
          <label>来源说明</label>
          <input type="text" id="generateSource" placeholder="例如：系统奖励、活动发放" value="admin" />
        </div>
        <button type="submit" class="button button-primary">生成积分</button>
      </form>
    </div>

    <!-- 分配积分 -->
    <div class="card">
      <h2>📤 分配积分</h2>
      <form id="allocateForm" onsubmit="return allocateCredits(event)">
        <div class="form-group">
          <label>用户 UUID</label>
          <input type="text" id="allocateUserId" placeholder="0000-0000-0000-0000" required />
        </div>
        <div class="form-group">
          <label>分配数量</label>
          <input type="number" id="allocateAmount" min="1" max="1000" value="10" required />
        </div>
        <button type="submit" class="button button-primary">分配积分</button>
      </form>
    </div>

    <!-- 回收积分 -->
    <div class="card">
      <h2>📥 回收积分</h2>
      <form id="recycleForm" onsubmit="return recycleCredits(event)">
        <div class="form-group">
          <label>用户 UUID</label>
          <input type="text" id="recycleUserId" placeholder="0000-0000-0000-0000" required />
        </div>
        <div class="form-group">
          <label>积分 ID 列表</label>
          <textarea id="recycleCreditIds" rows="3" placeholder="输入积分 ID，每行一个" required></textarea>
        </div>
        <button type="submit" class="button button-warning">回收积分</button>
      </form>
    </div>

    <!-- ZCnet 节点管理 -->
    <div class="card">
      <h2>🌐 ZCnet 节点</h2>
      <form id="registerNodeForm" onsubmit="return registerNode(event)">
        <div class="form-group">
          <label>节点 ID</label>
          <input type="text" id="nodeId" placeholder="node-1" required />
        </div>
        <div class="form-group">
          <label>节点 URL</label>
          <input type="url" id="nodeUrl" placeholder="http://192.168.1.100:5000" required />
        </div>
        <div class="form-group">
          <label>共享密钥</label>
          <input type="text" id="nodeSecret" placeholder="共享密钥" required />
        </div>
        <button type="submit" class="button button-primary">注册节点</button>
      </form>
      <div id="nodeList" class="node-list"></div>
    </div>
  </div>

  <!-- 积分池数据 -->
  <div class="card">
    <h2>📋 积分池数据</h2>
    <div class="data-controls">
      <button onclick="exportPoolData()" class="button">导出数据</button>
      <button onclick="importPoolData()" class="button button-warning">导入数据</button>
      <button onclick="syncWithNode()" class="button button-primary">同步到节点</button>
    </div>
    <textarea id="poolDataExport" rows="10" class="code-editor" readonly></textarea>
  </div>

  <!-- 操作历史 -->
  <div class="card">
    <h2>📜 操作历史</h2>
    <div id="historyList" class="history-list"></div>
  </div>
</div>

<style>
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  margin-bottom: 30px;
}

.stat-card {
  background: var(--bg-secondary);
  padding: 20px;
  border-radius: 10px;
  text-align: center;
}

.stat-value {
  font-size: 2em;
  font-weight: bold;
  color: var(--accent-color);
  margin: 10px 0;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 20px;
  margin-bottom: 30px;
}

.card {
  background: var(--bg-secondary);
  padding: 20px;
  border-radius: 10px;
}

.form-group {
  margin-bottom: 15px;
}

.form-group label {
  display: block;
  margin-bottom: 5px;
  color: var(--text-secondary);
}

.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 10px;
  border: 1px solid var(--border-color);
  border-radius: 5px;
  background: var(--bg-tertiary);
  color: var(--text-primary);
}

.code-editor {
  font-family: 'Consolas', 'Monaco', monospace;
  font-size: 0.9em;
}

.node-list,
.history-list {
  margin-top: 15px;
  max-height: 300px;
  overflow-y: auto;
}

.node-item,
.history-item {
  padding: 10px;
  border-bottom: 1px solid var(--border-color);
  font-size: 0.9em;
}

.data-controls {
  display: flex;
  gap: 10px;
  margin-bottom: 15px;
}

.alert {
  padding: 15px;
  border-radius: 5px;
  margin-bottom: 20px;
}

.alert-success {
  background: rgba(0, 200, 83, 0.2);
  border: 1px solid var(--success-color);
  color: var(--success-color);
}

.alert-error {
  background: rgba(244, 67, 54, 0.2);
  border: 1px solid var(--error-color);
  color: var(--error-color);
}
</style>

<script>
// 加载积分池统计
async function loadStats() {
  try {
    const response = await fetch('/api/zcnet/credit-pool/stats');
    const data = await response.json();
    
    if (data.success) {
      document.getElementById('availableCredits').textContent = data.stats.available;
      document.getElementById('allocatedCredits').textContent = data.stats.allocated;
      document.getElementById('totalGenerated').textContent = data.stats.totalGenerated;
      document.getElementById('totalRecycled').textContent = data.stats.totalRecycled;
      
      // 显示历史记录
      const historyList = document.getElementById('historyList');
      historyList.innerHTML = data.stats.history.slice(-20).reverse().map(h => `
        <div class="history-item">
          <strong>${h.action}</strong> - ${h.amount} 积分 
          ${h.targetUser ? `用户：${h.targetUser}` : ''}
          操作者：${h.operator}
          <br><small>${new Date(h.timestamp).toLocaleString()}</small>
        </div>
      `).join('');
    }
  } catch (error) {
    console.error('加载统计失败:', error);
  }
}

// 加载节点列表
async function loadNodes() {
  try {
    const response = await fetch('/api/zcnet/nodes');
    const data = await response.json();
    
    if (data.success) {
      const nodeList = document.getElementById('nodeList');
      nodeList.innerHTML = Object.entries(data.nodes).map(([id, node]) => `
        <div class="node-item">
          <strong>${id}</strong><br>
          URL: ${node.url}<br>
          注册时间：${new Date(node.registeredAt).toLocaleString()}
        </div>
      `).join('') || '<p>暂无已注册节点</p>';
    }
  } catch (error) {
    console.error('加载节点失败:', error);
  }
}

// 生成积分
async function generateCredits(event) {
  event.preventDefault();
  
  const amount = parseInt(document.getElementById('generateAmount').value);
  const source = document.getElementById('generateSource').value;
  
  try {
    const response = await fetch('/api/zcnet/credit-pool/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount, source })
    });
    
    const data = await response.json();
    if (data.success) {
      alert(`成功生成 ${data.count} 个积分`);
      loadStats();
    } else {
      alert(`失败：${data.error}`);
    }
  } catch (error) {
    alert(`错误：${error.message}`);
  }
  
  return false;
}

// 分配积分
async function allocateCredits(event) {
  event.preventDefault();
  
  const userId = document.getElementById('allocateUserId').value;
  const amount = parseInt(document.getElementById('allocateAmount').value);
  
  try {
    const response = await fetch('/api/zcnet/credit-pool/allocate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, amount })
    });
    
    const data = await response.json();
    if (data.success) {
      alert(`成功分配 ${data.count} 个积分给用户 ${userId}`);
      loadStats();
    } else {
      alert(`失败：${data.error}`);
    }
  } catch (error) {
    alert(`错误：${error.message}`);
  }
  
  return false;
}

// 回收积分
async function recycleCredits(event) {
  event.preventDefault();
  
  const userId = document.getElementById('recycleUserId').value;
  const creditIds = document.getElementById('recycleCreditIds').value
    .split('\n')
    .map(id => id.trim())
    .filter(id => id);
  
  try {
    const response = await fetch('/api/zcnet/credit-pool/recycle', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, creditIds })
    });
    
    const data = await response.json();
    if (data.success) {
      alert(`成功回收 ${data.recycled.length} 个积分`);
      loadStats();
    } else {
      alert(`失败：${data.error}`);
    }
  } catch (error) {
    alert(`错误：${error.message}`);
  }
  
  return false;
}

// 注册节点
async function registerNode(event) {
  event.preventDefault();
  
  const nodeId = document.getElementById('nodeId').value;
  const nodeUrl = document.getElementById('nodeUrl').value;
  const sharedSecret = document.getElementById('nodeSecret').value;
  
  try {
    const response = await fetch('/api/zcnet/register-node', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nodeId, nodeUrl, sharedSecret })
    });
    
    const data = await response.json();
    if (data.success) {
      alert(`节点 ${nodeId} 注册成功`);
      loadNodes();
    } else {
      alert(`失败：${data.error}`);
    }
  } catch (error) {
    alert(`错误：${error.message}`);
  }
  
  return false;
}

// 导出积分池数据
async function exportPoolData() {
  try {
    const response = await fetch('/api/zcnet/credit-pool/stats');
    const data = await response.json();
    
    document.getElementById('poolDataExport').value = JSON.stringify(data, null, 2);
  } catch (error) {
    alert(`错误：${error.message}`);
  }
}

// 导入积分池数据
async function importPoolData() {
  const dataStr = document.getElementById('poolDataExport').value;
  
  if (!dataStr) {
    alert('请输入要导入的数据');
    return;
  }
  
  try {
    const data = JSON.parse(dataStr);
    // 这里可以添加导入逻辑
    alert('导入功能开发中...');
  } catch (error) {
    alert(`无效的 JSON 数据：${error.message}`);
  }
}

// 同步到节点
async function syncWithNode() {
  const nodeId = prompt('输入目标节点 ID:');
  if (!nodeId) return;
  
  try {
    const response = await fetch('/api/zcnet/sync-credit-pool', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nodeId, merge: true })
    });
    
    const data = await response.json();
    if (data.success) {
      alert('同步成功');
    } else {
      alert(`失败：${data.error}`);
    }
  } catch (error) {
    alert(`错误：${error.message}`);
  }
}

// 初始化
loadStats();
loadNodes();
setInterval(loadStats, 30000);  // 每 30 秒刷新统计
</script>
