<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>零核服务器 - <%= targetUser.name %>的个人介绍</title>
    <%- include('./partials/head'); %>
    <style>
        .intro-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .intro-header {
            position: relative;
            background: linear-gradient(135deg, var(--bg-tertiary), var(--bg-secondary));
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 20px;
            border: 1px solid var(--border-color);
        }
        
        .intro-header-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 150px;
            background-image: url('<%= backgroundUrl %>');
            background-size: cover;
            background-position: center;
            z-index: 1;
        }
        
        .intro-header-content {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            padding: 20px;
            color: white;
            min-height: 150px;
        }
        
        .intro-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 3px solid white;
            margin-right: 20px;
            object-fit: cover;
        }
        
        .intro-user-info {
            flex: 1;
        }
        
        .intro-username {
            font-size: 1.8rem;
            margin: 0 0 5px 0;
        }
        
        .intro-uuid {
            font-size: 1rem;
            opacity: 0.8;
            margin: 0;
        }
        
        .intro-stats {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 8px;
            padding: 15px;
            margin-left: 20px;
            min-width: 200px;
        }
        
        .intro-stat-item {
            margin-bottom: 8px;
        }
        
        .intro-stat-label {
            font-weight: bold;
            color: var(--accent-color);
        }
        
        .intro-content {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 20px;
            margin-top: 20px;
        }
        
        .intro-content h1, .intro-content h2, .intro-content h3 {
            color: var(--accent-color);
        }
        
        .intro-content a {
            color: var(--accent-color);
        }
        
        .intro-content pre {
            background: var(--bg-tertiary);
            padding: 10px;
            border-radius: 5px;
            overflow-x: auto;
        }
        
        .intro-content code {
            background: var(--bg-tertiary);
            padding: 2px 4px;
            border-radius: 3px;
        }
        
        .intro-content blockquote {
            border-left: 3px solid var(--accent-color);
            padding-left: 15px;
            margin-left: 0;
            color: var(--text-secondary);
        }
    </style>
</head>
<body>
    <%- include('./partials/sidebar', { user: user, currentPath: currentPath }); %>

    <div class="content">
        <div class="intro-container">
            <div class="intro-header">
                <div class="intro-header-bg"></div>
                <div class="intro-header-content">
                    <img src="<%= targetUser.avatar || '/data/user/' + targetUser.UUID + '/avatar.jpg' %>" alt="头像" class="intro-avatar" onerror="this.src='/images/default-avatar.png'">
                    <div class="intro-user-info">
                        <h1 class="intro-username"><%= targetUser.name %></h1>
                        <p class="intro-uuid"><%= targetUser.UUID %></p>
                    </div>
                    <div class="intro-stats">
                        <div class="intro-stat-item">
                            <span class="intro-stat-label">积分数量:</span>
                            <span><%= targetUser.points || 0 %></span>
                        </div>
                        <div class="intro-stat-item">
                            <span class="intro-stat-label">注册时间:</span>
                            <span><%= new Date(targetUser.time).toLocaleString() %></span>
                        </div>
                        <div class="intro-stat-item">
                            <span class="intro-stat-label">上次登录:</span>
                            <span><%= targetUser.lastLoginDate || '未知' %></span>
                        </div>
                        <div class="intro-stat-item">
                            <span class="intro-stat-label">权限:</span>
                            <span><%= targetUser.author %></span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="intro-content">
                <%- introContent %>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts'); %>
    
    <script>
        // 确保图片加载完成后再调整布局
        window.addEventListener('load', function() {
            const bgImg = document.querySelector('.intro-header-bg');
            if (bgImg) {
                bgImg.style.backgroundImage = `url('${bgImg.style.backgroundImage}')`;
            }
        });
    </script>
</body>
</html>